# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Model weights cache (large files, use Docker named volumes)
.cache/

# Generated audio output
output/*.wav
output/*.mp3
output/*/

# Voice cloning samples (may contain personal audio)
sample_audio/*.wav
sample_audio/*.mp3
sample_audio/*.flac
sample_audio/*.m4a

# Speaker profiles (contain speaker embeddings extracted from personal audio)
speaker_profiles/*.pt

# Environment variables
.env
*.env

# Claude Code
# settings.json はプロジェクト共有設定のため追跡する
# memory/ など個人データは除外
.claude/*
!.claude/settings.json

# Editor
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Docker build artifacts
*.tar

# Fine-tuning data and checkpoints (personal audio / large files)
finetune_data/*.wav
finetune_data/*.mp3
finetune_data/*.jsonl
finetune_output/*/
# 公式スクリプトはホストに配置してコンテナへマウントする（gitignore 対象外）
# finetuning/ ディレクトリ内の .py は追跡する
